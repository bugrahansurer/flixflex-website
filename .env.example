# ═══════════════════════════════════════════════════════════
# FlixFlex — Environment Variable Reference
#
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ═══════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
DATABASE_URL=

# ── NextAuth ────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Set to "1" in development to enable the fallback admin account
# when the database is unavailable. NEVER set in production.
NEXTAUTH_FALLBACK_ADMIN=

# ── Vercel Blob ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Upstash Redis (Rate Limiting) ───────────────────────────
# Optional — when both values are present, all rate limiters use
# Upstash Redis sliding-window (globally consistent across instances).
# When absent, an in-memory fixed-window fallback is used instead
# (per-instance; effective limit = max × serverless instance count).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI Providers ────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email / Notifications ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Encryption ──────────────────────────────────────────────
ENCRYPTION_KEY=

# ── Mux (Video) ─────────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
